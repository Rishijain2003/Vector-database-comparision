# Copy lines into repo-root .env (same file used by scripts/rag).

OPENAI_API_KEY=sk-...
# Optional chat model (default gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Endee (rag/endee_rag.py) — same as ingest
# ENDEE_BASE_URL=http://127.0.0.1:18080
# ENDEE_INDEX_NAME=dbpedia_10k_benchmark

# Qdrant (rag/qdrant_rag.py)
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_COLLECTION=dbpedia_10k_benchmark_native
# QDRANT_API_KEY=

# Optional retrieval / search tuning
# RAG_TOP_K=5
# ENDEE_EF=128
# QDRANT_HNSW_EF=128
